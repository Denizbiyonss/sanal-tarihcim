@{
    ViewData["Title"] = "Sanal Tarihçim | Yeni Kayıt";
    ViewBag.BodyStyle = "display: flex; justify-content: center; align-items: center; min-height: 100vh; background: var(--parchment);";
}

<div style="width: 100%; max-width: 500px; background: white; padding: 50px; border-radius: 15px; box-shadow: 0 20px 50px rgba(0,0,0,0.1); border-left: 5px solid var(--gold);">
    <div style="text-align: center; margin-bottom: 30px;">
        <h2 style="font-family: 'Cinzel Decorative'; font-size: 2rem; margin-bottom: 10px;">CEMİYETE KATILIN</h2>
        <p style="font-family: 'Playfair Display';">Tarihin akışını takip edenlerin arasına girin.</p>
    </div>

    <form style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div style="grid-column: span 1;">
            <label style="display: block; margin-bottom: 8px; font-size: 0.9rem;">Adınız</label>
            <input type="text" placeholder="İsim" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box;">
        </div>
        <div style="grid-column: span 1;">
            <label style="display: block; margin-bottom: 8px; font-size: 0.9rem;">Soyadınız</label>
            <input type="text" placeholder="Soyisim" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box;">
        </div>
        <div style="grid-column: span 2;">
            <label style="display: block; margin-bottom: 8px; font-size: 0.9rem;">E-Posta Adresiniz</label>
            <input type="email" placeholder="ornek@@arsiv.com" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box;">
        </div>
        <div style="grid-column: span 2;">
            <label style="display: block; margin-bottom: 8px; font-size: 0.9rem;">Parolanızı Belirleyin</label>
            <input type="password" placeholder="En az 8 karakter" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box;">
        </div>
        <div style="grid-column: span 2; display: flex; align-items: center; gap: 10px; font-size: 0.85rem;">
            <input type="checkbox" id="kvkk">
            <label for="kvkk">Arşiv kurallarını ve kullanım şartlarını kabul ediyorum.</label>
        </div>
        <button type="button" class="capsule-btn" style="grid-column: span 2; background: var(--gold); color: var(--ink); border: none; padding: 15px; font-weight: bold; cursor: pointer; margin-top: 10px;">KAYIT OL VE BAŞLA</button>
    </form>

    <p style="text-align: center; margin-top: 25px; font-size: 0.9rem;">
        Zaten üyeyim? <a href="/giris" style="color: var(--ink); font-weight: bold; text-decoration: underline;">Giriş Yap</a>
    </p>
</div>
