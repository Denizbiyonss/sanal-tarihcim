@{
    ViewData["Title"] = "Sanal Tarihçim | Eski Çağ Arşivi";
}

<div class="main-wrapper" style="border-top-color: #d4af37;">
    <header>
        <a href="/" class="logo">ANTİK ARŞİV</a>
        <nav><ul><li><a href="/">← ANA SAYFA</a></li></ul></nav>
    </header>

    <section class="section-title">
        <h2 style="color: #b8860b;">MEDENİYETİN ŞAFAĞI: ESKİ ÇAĞ</h2>
    </section>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 50px; max-width: 1400px; margin: 0 auto;">
        <div class="info-text">
            <p style="font-family: 'Playfair Display'; font-size: 1.4rem; line-height: 2; margin-bottom: 25px; text-align: justify;">
                Eski Çağ, insanlığın yazıyı bulmasıyla başlayan ve Batı Roma İmparatorluğu'nun çöküşüne kadar uzanan devasa bir süreci kapsar. Mezopotamya'nın verimli topraklarından Nil'in gizemli kıyılarına, Sümerlerin çivi yazısından Mısır'ın hiyerogliflerine kadar medeniyetin tüm temelleri bu dönemde atılmıştır.
            </p>
            <div style="background: rgba(212,175,55,0.1); padding: 30px; border-left: 5px solid #d4af37; border-radius: 5px;">
                <h4 style="margin-bottom: 10px;">Kritik Odak Noktaları:</h4>
                <ul style="list-style: none; line-height: 2.2;">
                    <li><i class="fas fa-check-circle" style="color: #b8860b;"></i> <strong>Sümerler:</strong> Tekerleğin ve yazının keşfi.</li>
                    <li><i class="fas fa-check-circle" style="color: #b8860b;"></i> <strong>Hititler:</strong> Anadolu'nun ilk merkezi devleti ve demir işçiliği.</li>
                    <li><i class="fas fa-check-circle" style="color: #b8860b;"></i> <strong>Antik Yunan:</strong> Felsefe, demokrasi ve olimpiyatların doğuşu.</li>
                </ul>
            </div>
        </div>
        <div class="book-card">
            <div class="book-frame" style="background: #e3c16f;">
                <img src="/images/eski.jfif" style="width: 100%; height: 500px; object-fit: cover; border-radius: 10px;">
            </div>
        </div>
    </div>
</div>
