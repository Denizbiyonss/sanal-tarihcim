@{
    ViewData["Title"] = "Sanal Tarihçim | Imperial Archive";
}

@section Styles {
    <style>
        :root {
            --gold: #d4af37;
            --ink: #1a1a1a;
            --paper: #f4e4bc;
        }
        body {
            margin: 0; padding: 0;
            background-color: var(--paper);
            background-image: url('https://www.transparenttextures.com/patterns/old-paper.png');
            position: relative;
            font-family: 'Lora', serif;
            color: var(--ink);
            line-height: 1.6;
        }
        h2, .logo { font-family: 'Cinzel', serif; letter-spacing: 2px; text-transform: uppercase; }
        .section-title h2 { font-size: 2.2rem; color: #4a3728; border-bottom: 2px solid var(--gold); display: inline-block; margin-bottom: 30px; text-shadow: 1px 1px 2px rgba(0,0,0,0.1); }
        .book-card h3 { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: #2c1e12; margin-bottom: 10px; font-weight: 700; }
        .book-card p { font-style: italic; font-size: 1rem; color: #443a30; padding: 0 15px; line-height: 1.4; }
        .book-card strong { color: #8b0000; font-family: 'Cinzel', serif; font-size: 0.9rem; display: block; margin-bottom: 5px; }
        .history-card { position: fixed; bottom: 30px; right: 30px; width: 380px; min-height: 200px; background: #fffdf5; border: 4px double var(--gold); padding: 25px; border-radius: 4px; box-shadow: 15px 15px 35px rgba(0,0,0,0.3); z-index: 10001; transform: rotate(-1deg); background-image: radial-gradient(rgba(212,175,55,0.08) 1px, transparent 0); background-size: 15px 15px; }
        .history-card h4 { font-family: 'Cinzel', serif; font-size: 1.3rem; margin: 0 0 15px 0; color: #8b4513; border-bottom: 2px solid var(--gold); padding-bottom: 10px; text-align: center; }
        #history-text { font-family: 'Playfair Display', serif; font-size: 1.2rem; line-height: 1.6; color: #222; font-weight: 500; text-align: center; }
        .history-card .close-btn { position: absolute; top: 10px; right: 15px; font-size: 1.8rem; cursor: pointer; color: var(--gold); transition: 0.3s; }
        .history-card .close-btn:hover { color: #8b0000; }
        .lantern-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 9999; background: radial-gradient(circle 180px at var(--x, 50%) var(--y, 50%), transparent 0%, rgba(0,0,0,0.88) 100%); display: none; }
        .night-mode-active .lantern-overlay { display: block; }
        .night-toggle { position: fixed; bottom: 20px; left: 20px; z-index: 10000; background: var(--gold); color: #000; border: none; padding: 15px; border-radius: 50%; cursor: pointer; box-shadow: 0 0 15px rgba(0,0,0,0.3); }
        .dark-section { background: #1a1a1a; color: #d4af37; padding: 60px 20px; border-top: 1px solid #333; }
        .contact-form { max-width: 600px; margin: 0 auto; display: flex; flex-direction: column; gap: 15px; }
        .contact-form input, .contact-form textarea { background: #2a2a2a; border: 1px solid #444; padding: 12px; color: #fff; border-radius: 5px; }
        .contact-form button { background: var(--gold); color: #111; border: none; padding: 15px; font-weight: bold; cursor: pointer; text-transform: uppercase; }
    </style>
}

<div class="lantern-overlay"></div>

<div class="history-card" id="history-card">
    <span class="close-btn" onclick="document.getElementById('history-card').style.display='none'">&times;</span>
    <h4><i class="fas fa-scroll"></i> Arşivden Bugün</h4>
    <p id="history-text">Kadim belgeler tozlarından arındırılıyor...</p>
</div>

<button class="night-toggle" onclick="toggleNightMode()" title="Gaz Lambasını Yak/Söndür">
    <i class="fas fa-lightbulb"></i>
</button>

<div class="main-wrapper">
    <header>
        <a href="/" class="logo">SANAL TARİHÇİM</a>
        <nav>
            <ul>
                <li><a href="/">Anasayfa</a></li>
                <li><a href="#hakkimizda">Hakkımızda</a></li>
                <li><a href="#iletisim">İletişim</a></li>
                <li><a href="/sepetim" class="btn-sepet"><i class="fas fa-shopping-bag"></i> SEPETİM (<span id="sepet-sayac">0</span>)</a></li>
                <li><a href="/giris"><i class="fas fa-user"></i> Giriş Yap</a></li>
                <li><a href="/uye-ol" style="background: var(--gold); color: #1a1a1a; padding: 5px 10px; border-radius: 5px; font-weight: bold;">Üye Ol</a></li>
            </ul>
        </nav>
    </header>

    <div class="map-banner">
        <img src="/images/dunyaharita.jpg" alt="Typus Orbis Terrarum">
        <div class="map-overlay">
            <h2 class="map-title">Dünyanın dört bir yanından arşivler...</h2>
            <p class="map-subtitle">Tarihin tozlu sayfaları, dijital dünyanın kapılarında.</p>
        </div>
    </div>

    <div class="section-title"><h2>Dünya Tarihçileri ve Yazarlar</h2></div>
    <div class="grid-container">
        <a href="/turk-tarihciler" class="capsule-btn"><i class="fas fa-pen-fancy"></i> Türk Tarihçiler</a>
        <a href="/alman-tarihciler" class="capsule-btn"><i class="fas fa-book"></i> Alman Tarihçiler</a>
        <a href="/fransiz-tarihciler" class="capsule-btn"><i class="fas fa-feather"></i> Fransız Tarihçiler</a>
        <a href="/ingiliz-tarihciler" class="capsule-btn"><i class="fas fa-university"></i> İngiliz Tarihçiler</a>
        <a href="/amerikan-tarihciler" class="capsule-btn"><i class="fas fa-flag-usa"></i> Amerikan Tarihçiler</a>
        <a href="/arap-tarihciler" class="capsule-btn"><i class="fas fa-mosque"></i> Arap Tarihçiler</a>
        <a href="/misir-tarihciler" class="capsule-btn"><i class="fas fa-scroll"></i> Mısır Tarihçiler</a>
        <a href="/yunan-tarihciler" class="capsule-btn"><i class="fas fa-landmark"></i> Yunan Tarihçiler</a>
    </div>

    <div class="section-title"><h2>Arşiv Kategorileri</h2></div>
    <div class="category-strip">
        <a href="/osmanli" class="cat-item"><i class="fas fa-star-and-crescent"></i> Osmanlı</a>
        <a href="/roma" class="cat-item"><i class="fas fa-columns"></i> Roma</a>
        <a href="/eski-cag" class="cat-item"><i class="fas fa-monument"></i> Eski Çağ</a>
        <a href="/orta-cag" class="cat-item"><i class="fas fa-fort-awesome"></i> Orta Çağ</a>
        <a href="/yeni-cag" class="cat-item"><i class="fas fa-compass"></i> Yeni Çağ</a>
        <a href="/modern-tarih" class="cat-item"><i class="fas fa-city"></i> Modern</a>
        <a href="/islam-tarihi" class="cat-item"><i class="fas fa-kaaba"></i> İslam Tarihi</a>
        <a href="/avrupa-tarihi" class="cat-item"><i class="fas fa-map-marked"></i> Avrupa</a>
    </div>

    <div class="section-title"><h2>Kütüphane Seçkileri</h2></div>

    <div class="shelf">
        <div class="book-card">
            <div class="book-frame"><img src="/images/osmkitap.jfif" alt="Book"></div>
            <h3 style="margin-top:20px;">Osmanlı Tarihine Kuşbakışı</h3>
            <p><strong>Yazar: Halil İnalcık</strong>İmparatorluğun yükseliş ve çöküş dinamiklerini sarsıcı bir dille anlatan, tarihçilerin kutbundan bir başyapıt.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/osmanli" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Osmanlı Tarihine Kuşbakışı', '/images/osmkitap.jfif')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame"><img src="/images/romakitap.jfif" alt="Book"></div>
            <h3 style="margin-top:20px;">Roma İmparatorluğu</h3>
            <p><strong>Yazar: Edward Gibbon</strong>Antik dünyanın en büyük gücünün nasıl parçalandığını ve modern dünyaya miras bıraktığı kadim düzeni keşfedin.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/roma" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Roma İmparatorluğu Tarihi', '/images/romakitap.jfif')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame"><img src="/images/savaskitap.jfif" alt="Book"></div>
            <h3 style="margin-top:20px;">Savaş Ve Barış</h3>
            <p><strong>Yazar: Lev Tolstoy</strong>Napolyon savaşlarının gölgesinde, Rus toplumunun ruhunu ve insanın kaderini yansıtan destansı bir tarih panoraması.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/savas-tarihi" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Savaş Ve Barış', '/images/savaskitap.jfif')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame"><img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?q=80&w=1000" alt="Sapiens"></div>
            <h3 style="margin-top:20px;">Sapiens</h3>
            <p><strong>Yazar: Yuval Noah Harari</strong>İnsanoğlunun avcı-toplayıcılıktan yapay zekaya uzanan, türümüzün biyolojik ve kültürel evrimini sorgulayan yolculuk.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/modern-tarih" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Sapiens', 'https://images.unsplash.com/photo-1589829085413-56de8ae18c73?q=80&w=1000')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame"><img src="/images/tufek.jfif" alt="Tüfek Mikrop ve Çelik"></div>
            <h3 style="margin-top:20px;">Tüfek, Mikrop ve Çelik</h3>
            <p><strong>Yazar: Jared Diamond</strong>Neden bazı toplumlar ilerledi de diğerleri geride kaldı? Coğrafyanın ve ekolojinin insan kaderi üzerindeki mutlak etkisi.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/dunya-tarihi" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Tüfek, Mikrop ve Çelik', '/images/tufek.jfif')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame"><img src="/images/mukaddime.jfif" alt="Mukaddime"></div>
            <h3 style="margin-top:20px;">Mukaddime</h3>
            <p><strong>Yazar: İbn-i Haldun</strong>Sosyoloji ve tarih felsefesinin temelleri. Devletlerin doğuşunu, yükselişini ve kaçınılmaz çöküşünü anlatan bir dâhinin kaleminden.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/islam-tarihi" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Mukaddime', '/images/mukaddime.jfif')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame"><img src="/images/sefiller.jfif" alt="Sefiller"></div>
            <h3 style="margin-top:20px;">Sefiller</h3>
            <p><strong>Yazar: Victor Hugo</strong>Fransız Devrimi'nin sancılı yıllarında, adaletin ve vicdanın peşindeki insanların epik ve hüzünlü hikayesi.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/avrupa-tarihi" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Sefiller', '/images/sefiller.jfif')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame"><img src="/images/nutuk.jfif" alt="Nutuk"></div>
            <h3 style="margin-top:20px;">Nutuk</h3>
            <p><strong>Yazar: Mustafa Kemal Atatürk</strong>Modern bir ulusun küllerinden doğuşu. Milli Mücadele'nin her safhasını bizzat liderinden dinleyeceğiniz en kıymetli arşiv belgesi.</p>
            <div style="display: flex; gap: 10px; margin-top: 15px; justify-content: center;">
                <a href="/turk-tarihciler" class="capsule-btn" style="font-size: 0.8rem;">İncele</a>
                <button onclick="sepeteEkle('Nutuk', '/images/nutuk.jfif')" class="capsule-btn" style="background: var(--gold); border: none; cursor: pointer;"><i class="fas fa-plus"></i></button>
            </div>
        </div>
    </div>

    <div id="hakkimizda" class="dark-section">
        <div class="section-title"><h2>Hakkımızda</h2></div>
        <div style="max-width: 800px; margin: 0 auto; text-align: center; margin-bottom: 50px;">
            <p style="font-size: 1.2rem;">Sanal Tarihçim, insanlık hafızasını tozlu raflardan dijital evrene taşımak için kurulmuş bir akademi ve arşividir. Bizim için her eser, geleceği aydınlatan bir meşaledir.</p>
        </div>

        <div id="iletisim" class="section-title"><h2>Arşivcilere Ulaşın</h2></div>
        <form class="contact-form" onsubmit="event.preventDefault(); alert('Mesajınız arşivlere mühürlendi!');">
            <input type="text" placeholder="Adınız Soyadınız" required>
            <input type="email" placeholder="E-posta Adresiniz" required>
            <textarea rows="5" placeholder="Tarihçimize sormak istediğiniz nedir?" required></textarea>
            <button type="submit">Mührü Gönder</button>
        </form>
        <div style="text-align: center; margin-top: 40px; font-size: 0.9rem;">
            <p><i class="fas fa-envelope"></i> iletisim@@sanaltarihcim.com</p>
            <p><i class="fas fa-map-marker-alt"></i> Imperial Archive Headquarters</p>
        </div>
    </div>

    <footer>
        <p>• MMXXVI • SANAL TARİHÇİM İMPARATORLUK ARŞİVLERİ •</p>
    </footer>
</div>

@section Scripts {
<script>
    const tarihOlaylari = [
        "1453: Fatih Sultan Mehmet, İstanbul'un fethi için büyük topları döktürmeye başladı. Çağ kapatan hazırlıklar!",
        "1915: Çanakkale Deniz Zaferi; İtilaf Devletleri donanması boğazın serin sularına gömüldü.",
        "1920: İstanbul, İtilaf Devletleri tarafından resmen işgal edildi; ancak milli irade asla teslim olmadı.",
        "1923: Mustafa Kemal Atatürk, yeni Türkiye'nin ekonomik temelini İzmir İktisat Kongresi'nde attı.",
        "1876: İlk Türk Anayasası olan Kanun-i Esasi ilan edilerek parlamenter sisteme ilk adım atıldı.",
        "1071: Malazgirt Zaferi ile Anadolu'nun kapıları Türklere sonsuza dek açıldı."
    ];
    function gununOlayiniGetir() {
        const d = new Date();
        const index = (d.getDate() + d.getMonth()) % tarihOlaylari.length;
        document.getElementById('history-text').innerText = tarihOlaylari[index];
    }
    const overlay = document.querySelector('.lantern-overlay');
    document.addEventListener('mousemove', (e) => {
        overlay.style.setProperty('--x', e.clientX + 'px');
        overlay.style.setProperty('--y', e.clientY + 'px');
    });
    function toggleNightMode() {
        document.body.classList.toggle('night-mode-active');
        const icon = document.querySelector('.night-toggle i');
        icon.className = document.body.classList.contains('night-mode-active') ? 'fas fa-moon' : 'fas fa-lightbulb';
    }
    function sayacGuncelle() {
        const sepet = JSON.parse(localStorage.getItem('tarihSepeti')) || [];
        const sayac = document.getElementById('sepet-sayac');
        if(sayac) sayac.innerText = sepet.length;
    }
    function sepeteEkle(isim, gorsel) {
        let sepet = JSON.parse(localStorage.getItem('tarihSepeti')) || [];
        if (sepet.some(item => item.ad === isim)) { alert("Bu hazine zaten sepetinde var babuş!"); return; }
        sepet.push({ ad: isim, resim: gorsel });
        localStorage.setItem('tarihSepeti', JSON.stringify(sepet));
        sayacGuncelle();
        alert(isim + " başarıyla sepete eklendi!");
    }
    window.onload = () => { sayacGuncelle(); gununOlayiniGetir(); };
</script>
}
