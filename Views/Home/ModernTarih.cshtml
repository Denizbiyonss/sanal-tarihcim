@{
    ViewData["Title"] = "Sanal Tarihçim | Modern Tarih Arşivi";
}

<div class="main-wrapper" style="border-top-color: #2c3e50;">
    <header>
        <a href="/" class="logo">| YAKIN ÇAĞ</a>
        <nav><ul><li><a href="/">← ANA SAYFA</a></li></ul></nav>
    </header>

    <section class="section-title">
        <h2 style="color: #2c3e50;">MODERN TARİH: DEVRİMLER VE DÖNÜŞÜM</h2>
    </section>

    <div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; padding: 0 20px;">
        <div class="content">
            <p style="font-size: 1.4rem; line-height: 1.8; margin-bottom: 30px; font-family: 'Playfair Display'; text-align: justify;">
                SANAL TARİHÇİM ailesine göre modern tarihin en büyük öncüsü MUSTAFA KEMAL ATATÜRKTÜR. 1789 Fransız İhtilali ile meşalesi yakılan Yakın Çağ, imparatorlukların yıkılıp ulus devletlerin kurulduğu, teknolojinin insan hayatını kökten değiştirdiği ve küresel krizlerin yaşandığı en hareketli dönemdir.
            </p>

            <div style="background: #f4f4f4; border-left: 8px solid #2c3e50; padding: 25px; margin-bottom: 25px; box-shadow: 5px 5px 15px rgba(0,0,0,0.05);">
                <h3 style="font-family: 'Cinzel'; color: #2980b9; margin-bottom: 10px;">Sanayi Devrimi ve Buhar Gücü</h3>
                <p style="line-height: 1.6; font-style: italic;">İnsan ve hayvan gücünün yerini makinelerin almasıyla üretim şekli değişti. Köylerden kentlere büyük göçler başladı ve kapitalist dünya düzeninin temelleri atıldı.</p>
            </div>

            <div style="background: #fffafa; border: 1px solid #ddd; border-top: 5px solid #c0392b; padding: 25px; margin-bottom: 25px;">
                <h3 style="font-family: 'Cinzel'; color: #c0392b; margin-bottom: 10px;">İdeolojiler ve Dünya Savaşları</h3>
                <p style="line-height: 1.6;">20. yüzyıl, milliyetçilik, liberalizm ve sosyalizm gibi ideolojilerin çarpışmasına sahne oldu. İki büyük dünya savaşı, haritaları yeniden çizdi ve nükleer çağı başlattı.</p>
            </div>

            <div class="grid-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="capsule-btn" style="background: #2c3e50; color: white;"><i class="fas fa-industry"></i> Sanayi Devrimi</div>
                <div class="capsule-btn" style="border: 1px solid #2c3e50; color: #2c3e50;"><i class="fas fa-fist-raised"></i> Fransız İhtilali</div>
                <div class="capsule-btn" style="background: #2c3e50; color: white;"><i class="fas fa-globe-americas"></i> Soğuk Savaş</div>
                <div class="capsule-btn" style="border: 1px solid #2c3e50; color: #2c3e50;"><i class="fas fa-microchip"></i> Dijital Çağ</div>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame" style="border: 5px solid #2c3e50; border-radius: 10px; overflow: hidden; box-shadow: 10px 10px 30px rgba(0,0,0,0.2);">
                <img src="/images/atam.jfif" style="width: 100%; height: 500px; object-fit: cover;">
            </div>
            <p style="text-align: center; margin-top: 15px; font-family: 'Cinzel'; font-weight: bold; color: #2c3e50;">KENTLEŞME VE MODERNİTENİN YÜKSELİŞİ</p>
        </div>
    </div>

    <footer style="margin-top: 60px; text-align: center; padding-bottom: 30px; opacity: 0.7;">
        <p>• MMXXVI • MODERN TARİH DİJİTAL ARŞİVLERİ • ORDRE ET PROGRÈS •</p>
    </footer>
</div>
