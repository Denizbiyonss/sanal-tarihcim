@{
    ViewData["Title"] = "Sanal Tarihçim | Yeni Çağ Tarihi";
}

<div class="main-wrapper" style="border-top-color: #c5a059;">
    <header>
        <a href="/" class="logo">MODERNIS | YENİ ÇAĞ</a>
        <nav><ul><li><a href="/">← DÖNÜŞ</a></li></ul></nav>
    </header>

    <section class="section-title">
        <h2 style="color: #c5a059;">YENİ ÇAĞ: DÜNYANIN GENİŞLEMESİ</h2>
    </section>

    <div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; padding: 0 20px;">
        <div class="content">
            <p style="font-size: 1.4rem; line-height: 1.8; margin-bottom: 30px; font-family: 'Playfair Display'; text-align: justify;">
                1453'te surların yıkılmasıyla başlayan bu çağ, insan zihninin ve coğrafyanın sınırlarını paramparça etti. Matbaanın icadıyla bilgi yayıldı, pusulayla okyanuslar aşıldı ve skolastik düşünce yerini akılcı bir uyanışa bıraktı.
            </p>

            <div style="background: #fdfaf2; border-left: 8px solid #c5a059; padding: 25px; margin-bottom: 25px; box-shadow: 5px 5px 15px rgba(0,0,0,0.05);">
                <h3 style="font-family: 'Cinzel'; color: #b8860b; margin-bottom: 10px;">Coğrafi Keşifler ve Küreselleşme</h3>
                <p style="line-height: 1.6; font-style: italic;">İpek ve Baharat yollarının Osmanlı kontrolüne geçmesiyle Avrupalıların başlattığı arayış, yeni kıtaların keşfine ve sömürge imparatorluklarının doğuşuna yol açtı.</p>
            </div>

            <div style="background: #f4f7f9; border: 1px solid #ddd; border-top: 5px solid #2c3e50; padding: 25px; margin-bottom: 25px;">
                <h3 style="font-family: 'Cinzel'; color: #2c3e50; margin-bottom: 10px;">Rönesans ve Reform</h3>
                <p style="line-height: 1.6;">İtalya'da başlayan sanat ve bilim uyanışı (Rönesans), Almanya'da Kilise otoritesinin sorgulanmasıyla (Reform) birleşti. İnsan, evrenin merkezine geri döndü.</p>
            </div>

            <div class="grid-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="capsule-btn" style="background: #c5a059; color: white;"><i class="fas fa-ship"></i> Büyük Keşifler</div>
                <div class="capsule-btn" style="border: 1px solid #c5a059; color: #c5a059;"><i class="fas fa-print"></i> Matbaanın Gücü</div>
                <div class="capsule-btn" style="background: #c5a059; color: white;"><i class="fas fa-palette"></i> Rönesans Sanatı</div>
                <div class="capsule-btn" style="border: 1px solid #c5a059; color: #c5a059;"><i class="fas fa-crown"></i> Mutlak Krallıklar</div>
            </div>
        </div>

        <div class="book-card">
            <div class="book-frame" style="border: 5px solid #c5a059; border-radius: 10px; overflow: hidden; box-shadow: 10px 10px 30px rgba(0,0,0,0.2);">
                <img src="https://images.unsplash.com/photo-1589519160732-57fc498494f8?q=80&w=2000" style="width: 100%; height: 500px; object-fit: cover;">
            </div>
            <p style="text-align: center; margin-top: 15px; font-family: 'Cinzel'; font-weight: bold; color: #b8860b;">ESKİ DÜNYANIN SONU, YENİ DÜNYANIN ŞAFAĞI</p>
        </div>
    </div>

    <footer style="margin-top: 60px; text-align: center; padding-bottom: 30px; opacity: 0.7;">
        <p>• MMXXVI • YENİ ÇAĞ DİJİTAL ARŞİVLERİ • SAPERE AUDE •</p>
    </footer>
</div>
