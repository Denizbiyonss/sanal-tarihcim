<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Cinzel+Decorative:wght@700;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Montserrat:wght@300;500;700;900&family=Lora:ital@0;1&display=swap" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="@ViewBag.BodyStyle">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
